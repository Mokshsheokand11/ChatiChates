PORT=5001
# MongoDB Atlas (replace USER, PASS, cluster host, and DB name):
# MONGODB_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/chatichates?retryWrites=true&w=majority
# Local: mongodb://127.0.0.1:27017/chatichates
MONGODB_URI=
JWT_SECRET=your_jwt_secret
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
NODE_ENV=development
